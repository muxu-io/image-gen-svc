# Copy to `.env` and fill in to run the GPU integration suite against gated models.
#
#   cp .env.example .env
#   # edit .env, then:
#   poetry run pytest -m gpu
#
# The integration test harness (tests/integration/conftest.py) loads `.env`
# from the repo root and forwards HF_TOKEN into the container. Without a token,
# gated models (chroma -> FLUX.1-schnell, and possibly pony-v7-base) skip
# cleanly instead of failing.

# Hugging Face access token with read scope for gated repos.
# Create one at https://huggingface.co/settings/tokens
HF_TOKEN=
